__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.env
.venv/
env/
venv/
*.log
config.yaml

# Keep the vault folder structure in Git without tracking generated notes.
vault/**/*.md
vault/Assets/**
!vault/README.md
!vault/**/.gitkeep

# Ignore uploaded project files while keeping upload folder placeholders.
vault/Files/Uploads/**
!vault/Files/Uploads/
!vault/Files/Uploads/**/
!vault/Files/Uploads/**/.gitkeep
